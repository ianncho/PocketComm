#include <Arduino_GFX_Library.h>
#include <Adafruit_NeoPixel.h>
#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <ArduinoJson.h>

#define LED_PIN   8
#define TFT_BL    22
#define NUM_LEDS  1
#define TFT_DC    15
#define TFT_CS    14
#define TFT_SCLK  7
#define TFT_MOSI  6
#define TFT_RST   21

const char* WIFI_SSID = "TU_WIFI";
const char* WIFI_PASS = "TU_PASSWORD";

Arduino_DataBus *bus = new Arduino_ESP32SPI(TFT_DC, TFT_CS, TFT_SCLK, TFT_MOSI, -1);
Arduino_GFX *gfx = new Arduino_ST7789(bus, TFT_RST, 3, true, 172, 320, 0, 34);
Adafruit_NeoPixel strip(NUM_LEDS, LED_PIN, NEO_GRB + NEO_KHZ800);

#define C_BG     0x0000
#define C_BG2    0x0841
#define C_PURPLE 0x7BDB
#define C_TEXT   0xCE59
#define C_MUTED  0x52AA
#define C_DIM    0x2945
#define C_BORDER 0x18C3
#define C_GREEN  0x07E0
#define C_RED    0xF800

int currentApp = 0;
String uartBuffer = "";
String appName  = "POCKETCOMM";
String topRight = "";
String from1 = "", msg1 = ""; bool p1 = false;
String from2 = "", msg2 = ""; bool p2 = false;
String from3 = "", msg3 = ""; bool p3 = false;
String inputTxt = "";
bool wifiConnected = false;

void setLED(uint8_t r, uint8_t g, uint8_t b) {
    strip.setPixelColor(0, strip.Color(r, g, b));
    strip.show();
}

void drawText(int x, int y, String txt, uint16_t color, uint8_t size = 1) {
    gfx->setTextColor(color);
    gfx->setTextSize(size);
    gfx->setCursor(x, y);
    gfx->print(txt);
}

void drawScreen() {
    gfx->fillScreen(C_BG);

    // Barra superior
    gfx->fillRect(0, 0, gfx->width(), 18, C_BG2);
    gfx->drawFastHLine(0, 18, gfx->width(), C_BORDER);
    drawText(8, 5, appName, C_PURPLE);
    if (topRight.length() > 0)
        drawText(gfx->width() - topRight.length() * 6 - 8, 5, topRight,
                 wifiConnected ? C_GREEN : C_DIM);

    // Contenido - 3 filas
    int y = 28;
    if (from1.length() > 0) drawText(8,  y, from1, C_DIM);
    if (msg1.length()  > 0) drawText(48, y, msg1,  p1 ? C_PURPLE : C_TEXT);
    y += 28;
    if (from2.length() > 0) drawText(8,  y, from2, C_DIM);
    if (msg2.length()  > 0) drawText(48, y, msg2,  p2 ? C_PURPLE : C_TEXT);
    y += 28;
    if (from3.length() > 0) drawText(8,  y, from3, C_DIM);
    if (msg3.length()  > 0) drawText(48, y, msg3,  p3 ? C_PURPLE : C_TEXT);

    // Barra inferior
    gfx->fillRect(0, gfx->height() - 18, gfx->width(), 18, C_BG2);
    gfx->drawFastHLine(0, gfx->height() - 18, gfx->width(), C_BORDER);
    String inp = "> ";
    if (inputTxt.length() > 0) inp += inputTxt;
    inp += "_";
    drawText(8, gfx->height() - 13, inp, C_MUTED);

    // Puntos de navegacion
    for (int i = 0; i < 4; i++)
        gfx->fillCircle(gfx->width() - 12 - (3-i)*10, gfx->height()-10, 3,
                        i == currentApp ? C_PURPLE : C_DIM);
}

// Hacer llamada HTTP para el LuckFox (puente WiFi)
String doHTTPPost(const char* host, const char* path, const char* body, const char* token) {
    if (!wifiConnected) return "{\"error\":\"no_wifi\"}";

    WiFiClientSecure client;
    client.setInsecure();
    client.setTimeout(15);

    if (!client.connect(host, 443)) return "{\"error\":\"connect_failed\"}";

    String req = String("POST ") + path + " HTTP/1.1\r\n";
    req += String("Host: ") + host + "\r\n";
    req += "Content-Type: application/json\r\n";
    if (strlen(token) > 0)
        req += String("Authorization: Bearer ") + token + "\r\n";
    req += String("Content-Length: ") + strlen(body) + "\r\n";
    req += "Connection: close\r\n\r\n";
    req += body;

    client.print(req);

    String resp = "";
    bool bodyStarted = false;
    unsigned long t = millis();
    while (client.connected() && millis() - t < 15000) {
        if (client.available()) {
            String line = client.readStringUntil('\n');
            if (bodyStarted) resp += line + "\n";
            if (line == "\r") bodyStarted = true;
        }
    }
    client.stop();
    return resp.substring(0, 400);
}

void handleMessage(String &msg) {
    msg.trim();
    if (!msg.startsWith("{")) return;

    JsonDocument doc;
    DeserializationError err = deserializeJson(doc, msg);
    if (err) return;

    const char* type = doc["type"];
    if (!type) return;

    // Actualizar pantalla
    if (strcmp(type, "screen") == 0) {
        currentApp = doc["app"] | currentApp;
        const char* names[] = {"POCKETCOMM", "MENSAJES", "CHAT IA", "NOTAS"};
        const char* rights[] = {"", "esp-now", "groq", ""};
        if (currentApp >= 0 && currentApp < 4) {
            appName  = names[currentApp];
            topRight = rights[currentApp];
        }
        const char* v;
        v = doc["f1"]; if (v) from1 = String(v);
        v = doc["l1"]; if (v) msg1  = String(v);
        p1 = doc["p1"] | false;
        v = doc["f2"]; if (v) from2 = String(v);
        v = doc["l2"]; if (v) msg2  = String(v);
        p2 = doc["p2"] | false;
        v = doc["f3"]; if (v) from3 = String(v);
        v = doc["l3"]; if (v) msg3  = String(v);
        p3 = doc["p3"] | false;
        v = doc["input"]; if (v) inputTxt = String(v);
        drawScreen();
    }

    // Control LED RGB
    else if (strcmp(type, "led") == 0) {
        setLED(doc["r"] | 0, doc["g"] | 0, doc["b"] | 0);
    }

    // Puente HTTP para el LuckFox
    else if (strcmp(type, "http") == 0) {
        const char* url   = doc["url"]   | "";
        const char* body  = doc["body"]  | "";
        const char* token = doc["token"] | "";

        String surl = String(url);
        surl.replace("https://", "");
        int slash = surl.indexOf('/');
        String host = surl.substring(0, slash);
        String path = surl.substring(slash);

        String resp = doHTTPPost(host.c_str(), path.c_str(), body, token);

        JsonDocument r;
        r["type"] = "http_resp";
        r["code"] = 200;
        r["body"] = resp;
        String out;
        serializeJson(r, out);
        Serial.println(out);
    }

    // Estado WiFi
    else if (strcmp(type, "wifi_status") == 0) {
        JsonDocument r;
        r["type"]      = "wifi_resp";
        r["connected"] = wifiConnected;
        r["ip"]        = WiFi.localIP().toString();
        r["ssid"]      = WiFi.SSID();
        String out;
        serializeJson(r, out);
        Serial.println(out);
    }

    // ESP-NOW (futuro - etapa 3)
    else if (strcmp(type, "espnow_send") == 0) {
        // TODO: implementar en etapa 3
        Serial.println("ESP-NOW no implementado aun");
    }
}

void readUART() {
    while (Serial.available()) {
        char c = Serial.read();
        if (c == '\n') {
            if (uartBuffer.length() > 2) {
                handleMessage(uartBuffer);
            }
            uartBuffer = "";
        } else if (c >= 32 && c <= 126) {
            uartBuffer += c;
            if (uartBuffer.length() > 1024) uartBuffer = "";
        }
    }
}

void connectWiFi() {
    topRight = "wifi...";
    wifiConnected = false;
    drawScreen();

    WiFi.mode(WIFI_STA);
    WiFi.begin(WIFI_SSID, WIFI_PASS);

    int tries = 0;
    while (WiFi.status() != WL_CONNECTED && tries < 20) {
        delay(500);
        tries++;
    }

    if (WiFi.isConnected()) {
        wifiConnected = true;
        topRight = "wifi ok";
        drawScreen();
        setLED(0, 30, 0);

        // Avisarle al LuckFox que el WiFi esta listo
        JsonDocument d;
        d["type"] = "wifi_ready";
        d["ip"]   = WiFi.localIP().toString();
        String out;
        serializeJson(d, out);
        Serial.println(out);
    } else {
        wifiConnected = false;
        topRight = "sin wifi";
        drawScreen();
        setLED(30, 0, 0);
    }
}

void setup() {
    // Puerto serie — usado para comunicarse con el LuckFox
    Serial.begin(115200);

    // LED RGB
    strip.begin();
    strip.setBrightness(20);
    strip.show();
    setLED(20, 20, 20);

    // Display
    gfx->begin();
    gfx->fillScreen(C_BG);
    gfx->setFont();

    // Backlight al 60%
    ledcAttach(TFT_BL, 5000, 8);
    ledcWrite(TFT_BL, 80);

    // Pantalla inicial
    msg1 = "--:--";
    msg2 = "iniciando...";
    p1 = true;
    drawScreen();

    setLED(0, 0, 20);

    // Conectar WiFi
    connectWiFi();
}

void loop() {
    // Leer UART del LuckFox
    readUART();

    // Reconectar WiFi si se cae (cada 30 segundos)
    static unsigned long lastWifiCheck = 0;
    if (millis() - lastWifiCheck > 30000) {
        lastWifiCheck = millis();
        if (WiFi.status() != WL_CONNECTED) {
            wifiConnected = false;
            topRight = "reconectando";
            drawScreen();
            WiFi.reconnect();
            int tries = 0;
            while (WiFi.status() != WL_CONNECTED && tries < 10) {
                delay(500);
                tries++;
            }
            if (WiFi.isConnected()) {
                wifiConnected = true;
                topRight = "wifi ok";
                drawScreen();
                setLED(0, 30, 0);
            }
        }
    }

    delay(5);
}
